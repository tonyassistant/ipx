{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "ipx",
  "colors": {
    "primary": "#60A5FA",
    "light": "#93C5FD",
    "dark": "#2563EB"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
